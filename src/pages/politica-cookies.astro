---
import LegalLayout from "../layouts/LegalLayout.astro";
import { getPageById } from "../lib/woocommerce";

const page = await getPageById(14680);

let title = "POLÍTICA DE COOKIES";
let subtitle = "";
let content = "<p>Error al cargar el contenido.</p>";

if (page) {
    title = page.title?.rendered || title;
    const rawContent = page.content?.rendered || "";

    const parts = rawContent.split(/<\/p>/);
    if (parts.length > 0) {
        subtitle = parts[0].replace(/<p[^>]*>/g, "").trim();
        content = parts.slice(1).join("</p>");
    } else {
        content = rawContent;
    }
}
---

<LegalLayout title={title} subtitle={subtitle}>
    <div class="wp-content" set:html={content} />
</LegalLayout>
