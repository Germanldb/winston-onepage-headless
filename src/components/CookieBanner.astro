---

<div id="cookie-banner" class="cookie-banner" style="display: none;">
    <div class="cookie-content">
        <p class="cookie-text">
            Usamos cookies para mejorar su experiencia en nuestro sitio web. Al
            navegar por este sitio web, acepta nuestro uso de cookies.
        </p>
        <button id="accept-cookies" class="cookie-btn">ACEPTAR</button>
    </div>
</div>

<style>
    .cookie-banner {
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100%;
        background-color: #ffffff;
        box-shadow: 0 -5px 15px rgba(0, 0, 0, 0.05);
        z-index: 9999;
        padding: 1.25rem 0;
        border-top: 1px solid #eaeaea;
    }

    .cookie-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 2rem;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 5%;
    }

    .cookie-text {
        font-family: var(--font-body, "Helvetica", "Arial", sans-serif);
        font-size: 0.85rem;
        color: #888;
        margin: 0;
        line-height: 1.5;
        letter-spacing: 0.2px;
    }

    .cookie-btn {
        background-color: var(--color-green, #155338);
        color: #ffffff;
        border: none;
        padding: 0.75rem 2.5rem;
        font-family: var(--font-body, "Helvetica", "Arial", sans-serif);
        font-size: 0.85rem;
        font-weight: 700;
        cursor: pointer;
        transition: background-color 0.3s;
        letter-spacing: 1px;
        flex-shrink: 0;
    }

    .cookie-btn:hover {
        background-color: var(--color-black, #121212);
    }

    @media (max-width: 768px) {
        .cookie-content {
            flex-direction: column;
            text-align: center;
            gap: 1rem;
        }

        .cookie-btn {
            width: 100%;
        }
    }
</style>

<script>
    function initCookieBanner() {
        const banner = document.getElementById("cookie-banner");
        const btn = document.getElementById("accept-cookies");

        if (!banner || !btn) return;

        // Check if already accepted
        if (!localStorage.getItem("cookiesAccepted")) {
            banner.style.display = "block";
        }

        btn.addEventListener("click", () => {
            localStorage.setItem("cookiesAccepted", "true");
            banner.style.display = "none";
        });
    }

    // Run on astro:page-load for client side navigation support
    document.addEventListener("astro:page-load", initCookieBanner);

    // Initial load support
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initCookieBanner);
    } else {
        initCookieBanner();
    }
</script>
